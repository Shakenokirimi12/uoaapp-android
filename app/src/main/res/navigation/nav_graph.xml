<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_home">

    <!-- ── Bottom Nav Tabs ── -->

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.shakenokirimi12.uoa_app.ui.home.HomeFragment"
        android:label="@string/nav_home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_assignment_detail"
            app:destination="@id/navigation_assignment_detail" />
    </fragment>

    <fragment
        android:id="@+id/navigation_calendar"
        android:name="com.shakenokirimi12.uoa_app.ui.calendar.CalendarFragment"
        android:label="@string/nav_calendar"
        tools:layout="@layout/fragment_calendar" />

    <fragment
        android:id="@+id/navigation_courses"
        android:name="com.shakenokirimi12.uoa_app.ui.courses.CoursesFragment"
        android:label="@string/nav_courses"
        tools:layout="@layout/fragment_courses">
        <action
            android:id="@+id/action_courses_to_detail"
            app:destination="@id/navigation_course_detail" />
    </fragment>

    <fragment
        android:id="@+id/navigation_more"
        android:name="com.shakenokirimi12.uoa_app.ui.more.MoreFragment"
        android:label="@string/nav_more"
        tools:layout="@layout/fragment_more">
        <action android:id="@+id/action_more_to_reviews" app:destination="@id/navigation_reviews" />
        <action android:id="@+id/action_more_to_grades" app:destination="@id/navigation_grades" />
        <action android:id="@+id/action_more_to_facilities" app:destination="@id/navigation_facilities" />
        <action android:id="@+id/action_more_to_campus_map" app:destination="@id/navigation_campus_map" />
        <action android:id="@+id/action_more_to_notifications" app:destination="@id/navigation_notifications" />
        <action android:id="@+id/action_more_to_settings" app:destination="@id/navigation_settings" />
    </fragment>

    <!-- ── Gakushoku (accessible from More and Home) ── -->

    <fragment
        android:id="@+id/navigation_gakushoku"
        android:name="com.shakenokirimi12.uoa_app.ui.gakushoku.GakushokuFragment"
        android:label="@string/nav_gakushoku"
        tools:layout="@layout/fragment_gakushoku" />

    <!-- ── Settings ── -->

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.shakenokirimi12.uoa_app.ui.settings.SettingsFragment"
        android:label="@string/nav_settings"
        tools:layout="@layout/fragment_settings">
        <action android:id="@+id/action_settings_to_grades" app:destination="@id/navigation_grades" />
        <action android:id="@+id/action_settings_to_facilities" app:destination="@id/navigation_facilities" />
        <action android:id="@+id/action_settings_to_notifications" app:destination="@id/navigation_notifications" />
        <action android:id="@+id/action_settings_to_notify_times" app:destination="@id/navigation_notify_times" />
        <action android:id="@+id/action_settings_to_nav_settings" app:destination="@id/navigation_nav_settings" />
        <action android:id="@+id/action_settings_to_campus_map" app:destination="@id/navigation_campus_map" />
        <action android:id="@+id/action_settings_to_notification_debug" app:destination="@id/navigation_notification_debug" />
    </fragment>

    <!-- ── Academic ── -->

    <fragment
        android:id="@+id/navigation_grades"
        android:name="com.shakenokirimi12.uoa_app.ui.grades.GradesFragment"
        android:label="成績"
        tools:layout="@layout/fragment_grades" />

    <fragment
        android:id="@+id/navigation_facilities"
        android:name="com.shakenokirimi12.uoa_app.ui.facilities.FacilitiesFragment"
        android:label="施設利用状況"
        tools:layout="@layout/fragment_facilities" />

    <fragment
        android:id="@+id/navigation_course_detail"
        android:name="com.shakenokirimi12.uoa_app.ui.course.CourseDetailFragment"
        android:label="シラバス・ダッシュボード"
        tools:layout="@layout/fragment_course_detail">
        <action android:id="@+id/action_detail_to_syllabus" app:destination="@id/navigation_syllabus" />
    </fragment>

    <fragment
        android:id="@+id/navigation_syllabus"
        android:name="com.shakenokirimi12.uoa_app.ui.syllabus.SyllabusFragment"
        android:label="シラバス" />

    <fragment
        android:id="@+id/navigation_notifications"
        android:name="com.shakenokirimi12.uoa_app.ui.notifications.NotificationListFragment"
        android:label="通知"
        tools:layout="@layout/fragment_notification_list" />

    <fragment
        android:id="@+id/navigation_assignment_detail"
        android:name="com.shakenokirimi12.uoa_app.ui.assignment.AssignmentDetailFragment"
        android:label="課題詳細">
        <argument android:name="assignment_id" app:argType="integer" android:defaultValue="0" />
    </fragment>

    <!-- ── Reviews ── -->

    <fragment
        android:id="@+id/navigation_reviews"
        android:name="com.shakenokirimi12.uoa_app.ui.reviews.ReviewListFragment"
        android:label="授業評価">
        <action android:id="@+id/action_reviews_to_course_reviews" app:destination="@id/navigation_course_reviews" />
        <action android:id="@+id/action_reviews_to_instructor_reviews" app:destination="@id/navigation_instructor_reviews" />
        <action android:id="@+id/action_reviews_to_write_review" app:destination="@id/navigation_write_review" />
    </fragment>

    <fragment
        android:id="@+id/navigation_course_reviews"
        android:name="com.shakenokirimi12.uoa_app.ui.reviews.CourseReviewsFragment"
        android:label="レビュー">
        <argument android:name="course_id" app:argType="string" android:defaultValue="" />
        <argument android:name="course_name" app:argType="string" android:defaultValue="" />
        <argument android:name="syllabus_url" app:argType="string" android:defaultValue="" />
        <argument android:name="review_count" app:argType="integer" android:defaultValue="0" />
        <argument android:name="avg_rating" app:argType="float" android:defaultValue="0" />
        <action android:id="@+id/action_course_reviews_to_write" app:destination="@id/navigation_write_review" />
    </fragment>

    <fragment
        android:id="@+id/navigation_instructor_reviews"
        android:name="com.shakenokirimi12.uoa_app.ui.reviews.InstructorReviewsFragment"
        android:label="教員評価">
        <argument android:name="course_id" app:argType="string" android:defaultValue="" />
        <argument android:name="course_name" app:argType="string" android:defaultValue="" />
        <action android:id="@+id/action_instructor_reviews_to_write" app:destination="@id/navigation_write_review" />
    </fragment>

    <fragment
        android:id="@+id/navigation_write_review"
        android:name="com.shakenokirimi12.uoa_app.ui.reviews.WriteReviewFragment"
        android:label="レビューを書く">
        <argument android:name="course_id" app:argType="string" android:defaultValue="" />
        <argument android:name="course_name" app:argType="string" android:defaultValue="" />
        <argument android:name="review_type" app:argType="string" android:defaultValue="course" />
    </fragment>

    <!-- ── Settings sub-screens ── -->

    <fragment
        android:id="@+id/navigation_notify_times"
        android:name="com.shakenokirimi12.uoa_app.ui.settings.NotifyTimesFragment"
        android:label="通知タイミング" />

    <fragment
        android:id="@+id/navigation_nav_settings"
        android:name="com.shakenokirimi12.uoa_app.ui.settings.NavSettingsFragment"
        android:label="ナビゲーション設定" />

    <fragment
        android:id="@+id/navigation_campus_map"
        android:name="com.shakenokirimi12.uoa_app.ui.map.CampusMapFragment"
        android:label="キャンパスマップ" />

    <fragment
        android:id="@+id/navigation_notification_debug"
        android:name="com.shakenokirimi12.uoa_app.ui.debug.NotificationDebugFragment"
        android:label="通知診断" />

</navigation>
